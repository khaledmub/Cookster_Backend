APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
DB_QUEUE_RETRY_AFTER=7500
REDIS_QUEUE_RETRY_AFTER=7500
# Workers: php artisan queue:work --queue=video-processing,thumbnails,notifications,default --timeout=7200

# FFmpeg (HLS + fast-start MP4 ladder via ProcessVideoJob)
FFMPEG_BINARIES=/usr/bin/ffmpeg
FFPROBE_BINARIES=/usr/bin/ffprobe
FFMPEG_TIMEOUT=7200
FFMPEG_HLS_SEGMENT_SECONDS=2
FFMPEG_PRESET=fast
FFMPEG_GOP_SIZE=48
FFMPEG_VIDEO_PROFILE=main
FFMPEG_MP4_LADDER_HEIGHTS=360,720,1080

CACHE_STORE=redis
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Deep link / app link settings
ANDROID_APP_PACKAGE=com.cookster.cooksterapp
ANDROID_APP_SHA256=29:EA:D4:28:4B:EB:5A:11:DC:F7:F9:C0:25:CC:F5:36:63:72:4C:C3:85:7D:6A:5A:9E:EB:04:E5:29:2D:80:FF
IOS_TEAM_ID=
IOS_APP_BUNDLE_ID=

# --- Object storage (Laravel disk name is still "s3") ---
# Production uploads: set FILESYSTEM_DISK=s3 and fill the block below.
# Google Cloud Storage uses S3 interoperability (HMAC keys), not AWS.
#
# Example (GCP HMAC + path-style endpoint):
# FILESYSTEM_DISK=s3
# AWS_ACCESS_KEY_ID=GOOGxxxxxxxxxxxxxxxx
# AWS_SECRET_ACCESS_KEY=your_hmac_secret
# AWS_DEFAULT_REGION=europe-west3
# AWS_BUCKET=cookster-storage-v1
# AWS_ENDPOINT=https://storage.googleapis.com
# AWS_USE_PATH_STYLE_ENDPOINT=true
# Public URLs for objects (bucket needs allUsers: Storage Object Viewer if truly public):
# AWS_URL=https://storage.googleapis.com/cookster-storage-v1
#
# Admin UI / blades use AWS_CLOUD_FRONT_PATH + "videos/..." — set the same public base (with trailing slash):
# AWS_CLOUD_FRONT_PATH=https://storage.googleapis.com/cookster-storage-v1/
#
FILESYSTEM_DISK=local
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_ENDPOINT=
AWS_URL=
AWS_USE_PATH_STYLE_ENDPOINT=false
# Set true only if you use real AWS S3 object ACLs. GCS + uniform bucket access: leave unset (ACLs stripped automatically when AWS_ENDPOINT contains googleapis.com).
# S3_USE_OBJECT_ACL=

# Base URL for media in admin views (Videos/Audios); align with CDN_URL on production.
AWS_CLOUD_FRONT_PATH=
# Mobile reels + API media base. Leave EMPTY on test/staging (uses GCS direct URLs).
# Production (Google Cloud CDN — apply only after SSL on cdn.cookster.org is ACTIVE):
# CDN_URL=https://cdn.cookster.org
# CDN_ENABLED=true
# AWS_URL=https://cdn.cookster.org
# AWS_CLOUD_FRONT_PATH=https://cdn.cookster.org/
# When CDN_URL is set, CDN is on by default. Set CDN_ENABLED=false to force GCS only.
CDN_URL=
CDN_ENABLED=
CDN_FORCE_DIRECT_STORAGE=false
# Return video_url (CDN) + video_url_direct (GCS) for performance comparison
CDN_EXPOSE_DIRECT_URLS=true

# Amazon CloudFront signed URLs (optional; not used with Google Cloud CDN).
CLOUDFRONT_SIGNED_URLS_ENABLED=false
CLOUDFRONT_DOMAIN=https://cdn.myapp.com
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY_PATH=storage/app/cloudfront/private.pem
CLOUDFRONT_URL_TTL=86400
CDN_PRESIGN_CACHE_TTL=82800

# Mobile API: set false if the app builds URLs itself using media_base_url and video_url only
# API_MEDIA_USE_ABSOLUTE_VIDEO_URL=true

VITE_APP_NAME="${APP_NAME}"

# Hourly transcode progress email recipient
TRANSCODE_STATUS_EMAIL=
